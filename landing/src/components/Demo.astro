---

<section class="demo" id="demo">
  <div class="container">
    <h2 class="section-headline" style="text-align:center;">See It in Action</h2>
    <div class="demo-grid">
      <div class="demo-chat">
        <div class="chat-window">
          <div class="chat-header">Vendly Sales Bot</div>
          <div class="chat-body">
            <div class="msg msg-user">
              <div class="msg-bubble">Do you have Nike sneakers?</div>
            </div>
            <div class="msg msg-bot">
              <div class="msg-bubble">
                Yes! We have 3 models available:<br /><br />
                1. Air Max 90 — $89.99<br />
                2. Air Force 1 — $79.99<br />
                3. React Vision — $94.99<br /><br />
                All available in sizes 38-44.
              </div>
              <span class="cost-badge">$0.005</span>
            </div>
            <div class="msg msg-user">
              <div class="msg-bubble">How much is the Air Max?</div>
            </div>
            <div class="msg msg-bot">
              <div class="msg-bubble">
                The Air Max 90 is $89.99. We have it in black, white, and gray. Want me to check if another color is available?
              </div>
              <span class="cost-badge">$0.006</span>
            </div>
          </div>
        </div>
      </div>
      <div class="demo-transactions">
        <div class="card">
          <h4 style="color: var(--gray-400); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 16px;">Live Transaction Feed</h4>
          <div class="live-tx">
            <div class="live-dot"></div>
            <span class="tx-label">AI Inference</span>
            <span class="cost-badge">$0.005</span>
          </div>
          <div class="live-tx">
            <div class="live-dot"></div>
            <span class="tx-label">Catalog Query</span>
            <span class="cost-badge">$0.001</span>
          </div>
          <div class="live-tx">
            <div class="live-dot"></div>
            <span class="tx-label">AI Inference</span>
            <span class="cost-badge">$0.005</span>
          </div>
          <div class="live-tx">
            <div class="live-dot"></div>
            <span class="tx-label">Catalog Query</span>
            <span class="cost-badge">$0.001</span>
          </div>
          <div class="live-total">
            <span>Total conversation cost</span>
            <span class="cost-badge" style="font-size: 1rem;">$0.012</span>
          </div>
        </div>
      </div>
    </div>
    <div style="text-align:center; margin-top:40px;">
      <a href="https://t.me/vendly_sales_bot" class="btn btn-primary" target="_blank" rel="noopener">Message the Bot Now — It's Free to Try</a>
    </div>
  </div>
</section>

<style>
  .demo {
    background: var(--navy);
  }

  .demo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-top: 48px;
  }

  @media (min-width: 768px) {
    .demo-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .chat-window {
    background: var(--navy-light);
    border: 1px solid var(--navy-lighter);
    border-radius: 16px;
    overflow: hidden;
  }

  .chat-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--navy-lighter);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .chat-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .msg {
    display: flex;
    flex-direction: column;
  }

  .msg-user {
    align-items: flex-end;
  }

  .msg-bot {
    align-items: flex-start;
  }

  .msg-bubble {
    max-width: 85%;
    padding: 12px 16px;
    border-radius: 16px;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .msg-user .msg-bubble {
    background: var(--purple);
    border-bottom-right-radius: 4px;
  }

  .msg-bot .msg-bubble {
    background: var(--navy-lighter);
    border-bottom-left-radius: 4px;
  }

  .msg-bot .cost-badge {
    margin-top: 6px;
  }

  .live-tx {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(51, 65, 85, 0.5);
  }

  .live-dot {
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .tx-label {
    flex: 1;
    font-size: 0.9rem;
    color: var(--gray-300);
  }

  .live-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 16px;
    margin-top: 8px;
    font-weight: 600;
  }
</style>
