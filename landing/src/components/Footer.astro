<footer class="footer" id="footer">
  <div class="container">
    <h2 class="footer-headline">Stop Paying for AI You Don't Use</h2>
    <p class="footer-sub">Fund your wallet. Share your bot link. Pay per message.</p>
    <div class="footer-ctas">
      <a href="https://t.me/vendly_sales_bot" class="btn btn-primary" target="_blank" rel="noopener">Try the Demo Bot</a>
      <a href="https://vendly-rosy.vercel.app" class="btn btn-secondary" target="_blank" rel="noopener">Watch Transactions Live</a>
      <a href="https://github.com/t0k1dev/vendly" class="btn btn-secondary" target="_blank" rel="noopener">View Source Code</a>
    </div>
    <div class="footer-links">
      <a href="https://www.x402.org/" target="_blank" rel="noopener">x402 Protocol</a>
      <a href="https://stellar.org" target="_blank" rel="noopener">Stellar Network</a>
      <a href="https://github.com/t0k1dev/vendly" target="_blank" rel="noopener">GitHub</a>
    </div>
    <div class="footer-badge">
      Built for the x402 Hackathon on Stellar
    </div>
    <p class="footer-tagline">
      Vendly — AI sales agents powered by micropayments. You use it, you pay for it. Nothing more.
    </p>
  </div>
</footer>

<style>
  .footer {
    background: var(--navy-light);
    padding: 80px 0 40px;
    text-align: center;
  }

  .footer-headline {
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 12px;
  }

  @media (min-width: 768px) {
    .footer-headline {
      font-size: 2.5rem;
    }
  }

  .footer-sub {
    font-size: 1.15rem;
    color: var(--gray-400);
    margin-bottom: 40px;
  }

  .footer-ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  .footer-links {
    display: flex;
    gap: 32px;
    justify-content: center;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--gray-500);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--purple-light);
  }

  .footer-badge {
    display: inline-block;
    background: rgba(124, 58, 237, 0.15);
    border: 1px solid rgba(124, 58, 237, 0.3);
    color: var(--purple-light);
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 32px;
  }

  .footer-tagline {
    color: var(--gray-500);
    font-size: 0.85rem;
  }
</style>
