---
---

<section class="usecases" id="use-cases">
  <div class="container">
    <h2 class="section-headline" style="text-align:center;">Real Businesses, Real Savings</h2>
    <div class="cases-grid">
      <div class="card case-card">
        <div class="case-emoji">&#128094;</div>
        <h3>Retail</h3>
        <p class="case-story">A shoe store in Mexico City. 200 customer messages/day.</p>
        <div class="case-stats">
          <div class="case-stat">
            <span class="stat-label">Vendly cost</span>
            <span class="stat-value">~$1/day</span>
          </div>
          <div class="case-stat">
            <span class="stat-label">Previously</span>
            <span class="stat-value old">$1,200/mo</span>
          </div>
        </div>
      </div>
      <div class="card case-card">
        <div class="case-emoji">&#127856;</div>
        <h3>Food</h3>
        <p class="case-story">A bakery in Bogota. 50 custom cake inquiries/week.</p>
        <div class="case-stats">
          <div class="case-stat">
            <span class="stat-label">Vendly cost</span>
            <span class="stat-value">~$6/mo</span>
          </div>
          <div class="case-stat">
            <span class="stat-label">Previously</span>
            <span class="stat-value old">2 hrs/day</span>
          </div>
        </div>
      </div>
      <div class="card case-card">
        <div class="case-emoji">&#9986;&#65039;</div>
        <h3>Services</h3>
        <p class="case-story">A barber shop in Buenos Aires. 30 booking requests/day.</p>
        <div class="case-stats">
          <div class="case-stat">
            <span class="stat-label">Vendly cost</span>
            <span class="stat-value">~$0.90/day</span>
          </div>
          <div class="case-stat">
            <span class="stat-label">Previously</span>
            <span class="stat-value old">60% missed</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .usecases {
    background: var(--navy-light);
  }

  .cases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 48px;
  }

  @media (min-width: 768px) {
    .cases-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .case-emoji {
    font-size: 2.5rem;
    margin-bottom: 12px;
  }

  .case-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .case-story {
    color: var(--gray-400);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 20px;
  }

  .case-stats {
    display: flex;
    gap: 24px;
  }

  .case-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--gray-500);
  }

  .stat-value {
    font-weight: 700;
    color: var(--green);
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  .stat-value.old {
    color: var(--gray-400);
    text-decoration: line-through;
  }
</style>
